# 🍿️ DualSubs: 🎵 Spotify Transcripts - Anywhere MITM RuleSet
# desc = Spotify播客转译文本双语模块
# author = VirgilClyne
# homepage = https://github.com/DualSubs
# manual = https://github.com/DualSubs/Spotify/wiki/🍿-DualSubs:-🎵-Spotify

name = DualSubs Spotify Transcripts
hostname = spclient.wg.spotify.com, episode-transcripts.spotifycdn.com

# ===============================
# Spotify transcript-read-along
# 原规则：
# http-response ^https?:\/\/spclient\.wg\.spotify\.com\/transcript-read-along\/v2\/episode\/\w+
# requires-body=1
# binary-body-mode=1
# ===============================

0, 2, ^https?:\/\/spclient\.wg\.spotify\.com\/transcript-read-along\/v2\/episode\/\w+, accept-encoding
0, 1, ^https?:\/\/spclient\.wg\.spotify\.com\/transcript-read-along\/v2\/episode\/\w+, accept-encoding, identity
1, 100, ^https?:\/\/spclient\.wg\.spotify\.com\/transcript-read-along\/v2\/episode\/\w+, 


# ===============================
# Spotify episode-transcripts CDN
# 原规则：
# http-response ^https?:\/\/episode-transcripts\.spotifycdn\.com\/1\.0\/spotify:transcript:\w+
# requires-body=1
# binary-body-mode=1
# ===============================

0, 2, ^https?:\/\/episode-transcripts\.spotifycdn\.com\/1\.0\/spotify:transcript:\w+, accept-encoding
0, 1, ^https?:\/\/episode-transcripts\.spotifycdn\.com\/1\.0\/spotify:transcript:\w+, accept-encoding, identity
1, 100, ^https?:\/\/episode-transcripts\.spotifycdn\.com\/1\.0\/spotify:transcript:\w+, 