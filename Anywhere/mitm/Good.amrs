# Goodbility 会员解锁（GoodNotes + Notability）- 修正版
name = Goodbility 会员解锁
hostname = isi.csan.*, notability.com

# ========== 请求阶段：删除 X-RevenueCat-ETag 请求头 ==========
0, 100, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/(receipts|subscribers), 

# ========== 响应阶段：处理 receipts 接口（Apple 收据验证）==========
1, 5, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/receipts$, , requires-body=1

# ========== 响应阶段：处理 subscribers 接口（RevenueCat 订阅状态）==========
1, 5, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/subscribers\/[^/]+, , requires-body=1

# ========== 响应阶段：Notability 全局配置 ==========
1, 5, ^https?:\/\/notability\.com\/global, , requires-body=1