# Goodbility 会员解锁 - 修正版（按示例格式）
name = Goodbility 会员解锁
hostname = isi.csan.*, notability.com

# ========== 请求阶段：删除 X-RevenueCat-ETag 请求头 ==========
# 匹配 receipts 和 subscribers 接口（含查询参数）
0, 100, ^https:\/\/isi\.csan\.[a-z.]+\/v1\/(?:receipts|subscribers\/[^/?]+)(?:\?|$), 


# ========== 响应阶段：处理 GoodNotes 收据和订阅 ==========
# 先解压（处理 gzip/br 压缩）
0, 2, ^https:\/\/isi\.csan\.[a-z.]+\/v1\/(?:receipts|subscribers\/[^/?]+)(?:\?|$), accept-encoding
0, 1, ^https:\/\/isi\.csan\.[a-z.]+\/v1\/(?:receipts|subscribers\/[^/?]+)(?:\?|$), accept-encoding, identity

# 响应体修改（使用 1,100 按示例格式）
1, 100, ^https:\/\/isi\.csan\.[a-z.]+\/v1\/(?:receipts|subscribers\/[^/?]+)(?:\?|$), 


# ========== 响应阶段：处理 Notability 全局配置 ==========
# 解压
0, 2, ^https?:\/\/notability\.com\/global(?:\?|$), accept-encoding
0, 1, ^https?:\/\/notability\.com\/global(?:\?|$), accept-encoding, identity

# 响应体修改
1, 100, ^https?:\/\/notability\.com\/global(?:\?|$), 

