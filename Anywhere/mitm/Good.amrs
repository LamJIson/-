# Goodbility 会员解锁（GoodNotes + Notability）
name = Goodbility 会员解锁
hostname = isi.csan.*, notability.com

# 1. 请求阶段：删除 X-RevenueCat-ETag 请求头（原 deleteHeader.js）
0, 100, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/(receipts|subscribers), 

# 2. 响应阶段：处理 receipts 接口（Apple 收据验证）
1, 5, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/receipts$, 

# 3. 响应阶段：处理 subscribers 接口（RevenueCat 订阅状态）以及 Notability.com/global
1, 5, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/subscribers\/[^/]+$|^https?:\/\/notability\.com\/global, 