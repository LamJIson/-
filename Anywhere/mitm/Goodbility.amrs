# Goodbility / Notability / GoodNotes 会员解锁 - Anywhere MITM RuleSet

name = Goodbility会员解锁
hostname = isi.csan.*, notability.com

# ==================== Header 处理 ====================
0, 2, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/(receipts|subscribers), accept-encoding
0, 1, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/(receipts|subscribers), accept-encoding, identity

# ==================== 响应体解锁脚本 ====================
0, 100, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/(receipts$|subscribers\/[^/]+$), 

0, 100, ^https?:\/\/notability\.com\/global, 