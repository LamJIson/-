# Goodbility会员解锁
name = Goodbility会员解锁
hostname = isi.csan.*, notability.com

# 请求阶段：删除 X-RevenueCat-ETag 请求头
0, 100, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/(receipts|subscribers), 

# 响应阶段：统一 VIP 解锁（适用于 receipts/subscribers 和 notability.com/global）
1, 5, ^https:\/\/isi\.csan\.[a-z.]+\/.+\/(receipts$|subscribers\/[^/]+$), 

1, 5, ^https?:\/\/notability\.com\/global, 