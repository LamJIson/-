#!name=高德地图去广告 (Anywhere 极简硬编码版)
#!desc=最大程度使用 Base64 硬编码替换，减少 JS 执行，提升性能。
#!author=RuCu6, kelv1n1n, 可莉🅥 (Original), AI (Anywhere Pure Port)

name = Amap_Adblock_Pure
hostname = *.amap.com, m5.amap.com, m5-zb.amap.com, restapi.amap.com, apilocate.amap.com, ai.amap.com, sns.amap.com, oss.amap.com

# ==================== 1. Reject 规则 (域名拦截) ====================
# 沿用你的模板格式，Phase 1, Op 0, 动作 3 (Reject/Drop)
1, 0, ^https?://(amap-aos-info-nogw\.amap\.com|free-aos-cdn-image\.amap\.com|.*\.smtcdns\.com)/, 3

# ==================== 2. Map Local (完美模仿 GoodNotes 的 e30= 写法) ====================
# 核心思路：Phase 1 (Response), Op 6 (body-replace), 内容直接写 {} 的 Base64 (e30=)
# 这种写法不需要 JS 引擎参与，性能最高，最稳定！

1, 6, ^https?://m5-zb\.amap\.com/ws/ride/home/page/get_commuting_card\?, e30=
1, 6, ^https?://m5\.amap\.com/ws/shield/search_business/process/orderList\?, e30=
1, 6, ^https?://m5\.amap\.com/ws/shield/search/new_hotword\?, e30=
1, 6, ^https?://m5\.amap\.com/ws/faas/amap-navigation/card-service-(?:car-end|route-plan), e30=
1, 6, ^https?://m5\.amap\.com/ws/shield/search_poi/tips_adv\?, e30=
1, 6, ^https?://oss\.amap\.com/ws/banner/lists/\?, e30=
1, 6, ^https?://ai\.amap\.com/v1/ai_rec/, e30=
1, 6, ^https?://m5\.amap\.com/ws/aos/main/page/product/list\?, e30=
1, 6, ^https?://m5\.amap\.com/ws/faas/amap-navigation/(?:main-page-assets|main-page-location|ridewalk-end-fc|usr-profile-fc/homeV2), e30=
1, 6, ^https?://m5\.amap\.com/ws/(?:mapapi/hint_text/offline_data|message/notice/list|shield/search/new_hotword), e30=
1, 6, ^https?://m5\.amap\.com/ws/shield/scene/recommend\?, e30=
1, 6, ^https?://m5\.amap\.com/ws/valueadded/weather/v2\?, e30=
1, 6, ^https?://sns\.amap\.com/ws/msgbox/pull_mp\?, e30=
1, 6, ^https?://m5-zb\.amap\.com/ws/boss/(?:order/car/(?:feedback/get_card_questions|feedback/viptips|king_toolbox_car_bubble|remark/satisfactionConf|rights_information)|tips/onscene_visual_optimization), e30=
1, 6, ^https?://m5-zb\.amap\.com/ws/boss/(?:pay/web/paySuccess/info/request|transportation/diversion/resource/driving), e30=

# ==================== 3. Body Rewrite (动态删除节点) ====================
# 注意：这里不能像 GoodNotes 那样写死 Base64！
# 因为高德地图返回的是实时的搜索/导航数据，写死会导致地图白屏。
# 这里只能使用最精简的 JS (Phase 1, Op 4) 来动态剔除广告节点。

1, 4, ^https?://(m5|m5-zb|info)\.amap\.com/ws/(aos|boss|bus|c3frontend|faas|perception|promotion-web|shield|valueadded|sharedtrip), 



# ==================== 核心脚本处理 ====================
# Phase 1 (Response), Op 4 (script)
# 拦截所有 amap 流量，在 JS 内部解析 JSON 并精准剔除广告节点
1, 4, ^https?://.*\.amap\.com/, 

