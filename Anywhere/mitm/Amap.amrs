# 高德地图去广告 - Anywhere MITM RuleSet
# 原始作者：RuCu6, kelv1n1n, 可莉🅥
# 转换说明：
#   [Rule] DOMAIN → rewrite (op 0, sub-mode 2) 返回空响应
#   [Map Local] → rewrite (op 0, sub-mode 4) 返回 base64 编码的 {}
#   [Body Rewrite] JQ → body-json (op 5) delete 操作
#   [Script] → script (op 100) 需要自行 base64 编码 JS 源码
#   [MITM] → hostname 字段
name = 高德地图去广告
# 【核心修复】：只拦截营销/广告域名，绝对不要写 amap.com 或 *.amap.com！
# 这样 mps.amap.com (导航核心)、wprd.amap.com (地图瓦片) 等将直接透传，不会被拦截。
hostname = m5.amap.com, m5-zb.amap.com, oss.amap.com, ai.amap.com, sns.amap.com, info.amap.com


# ============================================================
# 1. 域名拦截 (原 [Rule])
#    rewrite op 0, sub-mode 2 = 返回 200 OK 空响应
# ============================================================
0, 0, ^https?://amap-aos-info-nogw\.amap\.com/.*, 2
0, 0, ^https?://free-aos-cdn-image\.amap\.com/.*, 2
0, 0, ^https?://[^/]*\.smtcdns\.com/.*, 2

# ============================================================
# 2. 本地响应重写 (原 [Map Local])
#    rewrite op 0, sub-mode 4 = 返回 base64 编码的数据
#    空 JSON {} 的 base64 为 e30=
# ============================================================
0, 0, ^https://m5-zb\.amap\.com/ws/ride/home/page/get_commuting_card\?, 4, e30=
0, 0, ^https://m5\.amap\.com/ws/shield/search_business/process/orderList\?, 4, e30=
0, 0, ^https://m5\.amap\.com/ws/shield/search/new_hotword\?, 4, e30=
0, 0, ^https://m5\.amap\.com/ws/faas/amap-navigation/card-service-(?:car-end|route-plan), 4, e30=
0, 0, ^https://m5\.amap\.com/ws/shield/search_poi/tips_adv\?, 4, e30=
0, 0, ^https://oss\.amap\.com/ws/banner/lists/\?, 4, e30=
0, 0, ^https://ai\.amap\.com/v1/ai_rec/, 4, e30=
0, 0, ^https://m5\.amap\.com/ws/aos/main/page/product/list\?, 4, e30=
0, 0, ^https://m5\.amap\.com/ws/faas/amap-navigation/(?:main-page-assets|main-page-location|ridewalk-end-fc|usr-profile-fc/homeV2), 4, e30=
0, 0, ^https://m5\.amap\.com/ws/(?:mapapi/hint_text/offline_data|message/notice/list|shield/search/new_hotword), 4, e30=
0, 0, ^https://m5\.amap\.com/ws/shield/scene/recommend\?, 4, e30=
0, 0, ^https://m5\.amap\.com/ws/valueadded/weather/v2\?, 4, e30=
0, 0, ^https://sns\.amap\.com/ws/msgbox/pull_mp\?, 4, e30=
0, 0, ^https://m5-zb\.amap\.com/ws/boss/(?:order/car/(?:feedback/get_card_questions|feedback/viptips|king_toolbox_car_bubble|remark/satisfactionConf|rights_information)|tips/onscene_visual_optimization), 4, e30=
0, 0, ^https://m5-zb\.amap\.com/ws/boss/(?:pay/web/paySuccess/info/request|transportation/diversion/resource/driving), 4, e30=

# ============================================================
# 3. 响应体精简 (原 [Body Rewrite])
#    body-json op 5, delete 操作删除指定字段
# ============================================================
1, 5, ^https://m5\.amap\.com/ws/shield/search_business/process/marketingOperationStructured\?, delete, $.data.commonMaterial
1, 5, ^https://m5\.amap\.com/ws/shield/search_business/process/marketingOperationStructured\?, delete, $.data.tipsOperationLocation
1, 5, ^https://m5\.amap\.com/ws/shield/search_business/process/marketingOperationStructured\?, delete, $.data.resourcePlacement
1, 5, ^https://m5\.amap\.com/ws/shield/search_poi/homepage\?, delete, $.history_tags
1, 5, ^https://m5-zb\.amap\.com/ws/sharedtrip/taxi/order_detail_car_tips\?, delete, $.data.carTips.data.popupInfo

# ============================================================
# 4. 动态脚本处理 (原 [Script])
#    script op 100, base64 编码的 JavaScript 源码
#    请将下方 SCRIPT_BASE64_HERE 替换为实际脚本的 base64
#    生成方式: base64 -w0 amap.js
