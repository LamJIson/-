# Spotify 歌词增强
name = Spotify Lyrics Enhance

hostname = api.spotify.com, spclient.wg.spotify.com

# Request 阶段
0, 100, ^https?://spclient\.wg\.spotify\.com/color-lyrics/v2/track/(.+)\?(.*)format=json, 

0, 100, ^https?://spclient\.wg\.spotify\.com/color-lyrics/v2/track/\w+\?(.*), 


# Response 阶段
1, 100, ^https?://api\.spotify\.com/v1/tracks\?, 


# 翻译歌词
1, 100, ^https?://spclient\.wg\.spotify\.com/color-lyrics/v2/track/(.+)\?(.*)subtype=Translate, 

1, 100, ^https?://spclient\.wg\.spotify\.com/color-lyrics/v2/track/\w+\?(.*)subtype=Translate, 


# 外部歌词
1, 100, ^https?://spclient\.wg\.spotify\.com/color-lyrics/v2/track/(.+)\?(.*)subtype=External, 

1, 100, ^https?://spclient\.wg\.spotify\.com/color-lyrics/v2/track/\w+\?(.*)subtype=External, 