# Spotify 歌词增强
name        = Spotify Lyrics Enhance
hostname    = api.spotify.com, spclient.wg.spotify.com

# 1. 跟踪响应（响应阶段）
1, 100, ^https?:\/\/api\.spotify\.com\/v1\/tracks\?, 


# 2. 歌词请求（JSON 格式，请求阶段）
0, 100, ^https?:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/.+\?.*format=json, 


# 3. 歌词请求（Proto 格式，请求阶段）
0, 100, ^https?:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/.+\?(?!.*format=json), 


# 4. 翻译歌词响应（JSON，响应阶段）
1, 100, ^https?:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=Translate, 


# 5. 翻译歌词响应（Proto，响应阶段）
1, 100, ^https?:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/.+\?.*subtype=Translate(?!.*format=json), 


# 6. 外部歌词响应（JSON，响应阶段）
1, 100, ^https?:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=External, 


# 7. 外部歌词响应（Proto，响应阶段）
1, 100, ^https?:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/.+\?.*subtype=External(?!.*format=json), 