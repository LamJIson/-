# 百词斩去广告 - Anywhere MITM RuleSet

name = 百词斩去广告
hostname = *.baicizhan.com, *.bczcdn.com, *.baicizhan.cn, notify.bczeducation.cn, ireading.baicizhan.com, advertise.baicizhan.com, advertise.bczeducation.cn, du.baicizhan.com, marketing-api.baicizhan.com, strategy.baicizhan.com

# ---------- Rules ----------
REJECT, ^https://ireading.baicizhan.com/api/ireading/new_reading/get_book_read_info\?book_id=\d+
REJECT, ^http://notify\.bczeducation\.cn/rpc/notify/get_remind_msgs/d+
REJECT, ^https://ireading\.baicizhan\.com/api/ireading/new_reading/get_ad_item
REJECT, ^https://ireading\.baicizhan\.com/api/ireading/new_reading/upload_ad_event
REJECT, ^https?://advertise\.(baicizhan|bczeducation)\.(cn|com)/rpc/advertise/.*
REJECT, ^https?://advertise\.(baicizhan|bczeducation)\.(cn|com)/api/advertise/.*
DIRECT, ^https?://advertise\.baicizhan\.com/api/advertise/vocabulary/getHomeAd
DIRECT, ^https?://advertise\.baicizhan\.com/my_vocabulary/.*
DOMAIN, advertise.bczeducation.cn, REJECT

# ---------- Scripts (内联 JS) ----------
# 1. bcz.js - 对应 get_user_info
SCRIPT, ^https?://du\.baicizhan\.com/api/ireading/new_reading/get_user_info$, type=http-response, script-

# 2. bczsb.js - 对应 get_user_read_book, get_books, foreign_journal_vip_status, book_package_vip_status
SCRIPT, ^https?://du\.baicizhan\.com/api/ireading/new_reading/(get_user_read_book\?bookId=\d+|get_books|membership/foreign_journal_vip_status|membership/book_package_vip_status)$, type=http-response, script-

# 3. bczlq.js - 对应 membership/infos
SCRIPT, ^https://marketing-api\.baicizhan\.com/api/v1/membership/infos, type=http-response, script-

# 4. bczrd.js - 对应 get_book_info
SCRIPT, ^https?://du\.baicizhan\.com/api/ireading/new_reading/get_book_info, type=http-response, script-

# 5. bczs.js - 对应 get_book_article, get_article_data, get_user_read_book, report_read
SCRIPT, ^https?://du\.baicizhan\.com/api/ireading/new_reading/(get_book_article|get_article_data|get_user_read_book|report_read), type=http-response, script-

# 6. bczvipnew.js - 对应 get_member_info_page
SCRIPT, ^https://strategy\.baicizhan\.com/api/strategy/get_member_info_page, type=http-response, script-