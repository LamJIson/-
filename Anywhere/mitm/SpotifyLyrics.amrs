#!name = 🍿️ DualSubs: 🎵 Spotify for Anywhere
#!desc = Spotify 增强及双语歌词｜Anywhere 适配版｜脚本 Base64 留空
#!openUrl = http://boxjs.com/#/app/DualSubs.Spotify
#!author = VirgilClyne[https://github.com/VirgilClyne]
#!homepage = https://DualSubs.github.io/guide/spotify
#!icon = https://github.com/DualSubs/Spotify/raw/main/src/assets/icon_rounded.png
#!category = 🍿️ DualSubs
#!date = 2026-06-15
#!version = 1.9.12-anywhere-blank-base64
#!arguments = Types:"Translate,External",Languages[0]:"AUTO",Languages[1]:"ZH-HANS",Vendor:"Google",LrcVendor:"NeteaseMusic",LogLevel:"WARN"
#!arguments-desc = Types: [歌词] 启用类型（多选）\n    ├ Translate: 翻译歌词（翻译器）\n    └ External: 外部歌词（外部源）\n请选择要添加的歌词选项，如果为多选，则会自动决定提供的歌词类型。\n\nLanguages[0]: [翻译器] 主语言（源语言）\n    ├ AUTO: 自动 - Automatic\n    ├ ZH: 中文（自动）\n    ├ ZH-HANS: 中文（简体）\n    ├ ZH-HK: 中文（香港）\n    ├ ZH-HANT: 中文（繁体）\n    └ EN: English - 英语（自动）\n仅当源语言识别不准确时更改此选项。\n\nLanguages[1]: [翻译器] 副语言（目标语言）\n    ├ ZH: 中文（自动）\n    ├ ZH-HANS: 中文（简体）\n    ├ ZH-HK: 中文（香港）\n    ├ ZH-HANT: 中文（繁体）\n    └ EN: English - 英语（自动）\n请指定翻译歌词的目标语言。\n\nVendor: [翻译器] 服务商API\n    ├ Google: Google Translate\n    └ Microsoft: Microsoft Translator（需填写API）\n\nLrcVendor: [歌词] 服务商API\n    ├ NeteaseMusic: 网易云音乐（官方）\n    ├ QQMusic: QQ音乐（官方）\n    └ NeteaseMusicNodeJS: 网易云音乐 NodeJS API\n\nLogLevel: [调试] 日志等级\n    ├ OFF: 🔴 关闭\n    ├ ERROR: ❌ 错误\n    ├ WARN: ⚠️ 警告\n    ├ INFO: ℹ️ 信息\n    ├ DEBUG: 🅱️ 调试\n    └ ALL: 全部

# Anywhere 规则说明：
# 0, 100 = Request Script / Request Rewrite
# 1, 100 = Response Script / Response Rewrite
# 0, 2   = Request Header Delete
# 0, 1   = Request Header Add
# Response 脚本读取 body 前，建议先在 Request 阶段处理 accept-encoding。
# 默认参数：Types="Translate,External"&Languages[0]="AUTO"&Languages[1]="ZH-HANS"&Vendor="Google"&LrcVendor="NeteaseMusic"&LogLevel="WARN"

name = 🍿️ DualSubs: 🎵 Spotify for Anywhere
hostname = api.spotify.com, spclient.wg.spotify.com, *-spclient.spotify.com

# ==================================================
# 1. Tracks response JSON
# 原始脚本：response.bundle.js
# Phase: Response
# Operation: Rewrite
# Script Base64: 请自行填写
# ==================================================
0, 2, ^https?:\/\/api\.spotify\.com\/v1\/tracks\?, accept-encoding
0, 1, ^https?:\/\/api\.spotify\.com\/v1\/tracks\?, accept-encoding, identity
1, 100, ^https?:\/\/api\.spotify\.com\/v1\/tracks\?, 
# ==================================================
# 2. Lyrics request JSON
# 原始脚本：request.bundle.js
# Phase: Request
# Operation: Rewrite
# Script Base64: 请自行填写
# ==================================================
0, 100, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?.*format=json.*, 

# ==================================================
# 3. Lyrics request Proto
# 原始脚本：request.bundle.js
# Phase: Request
# Operation: Rewrite
# Script Base64: 请自行填写
# ==================================================
0, 100, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*, 

# ==================================================
# 4. Translate lyrics response JSON
# 原始脚本：Translate.response.bundle.js
# Phase: Response
# Operation: Rewrite
# Script Base64: 请自行填写
# ==================================================
0, 2, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=Translate.*, accept-encoding
0, 1, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=Translate.*, accept-encoding, identity
1, 100, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=Translate.*, 
# ==================================================
# 5. Translate lyrics response Proto
# 原始脚本：Translate.response.bundle.js
# Phase: Response
# Operation: Rewrite
# Script Base64: 请自行填写
# ==================================================
0, 2, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*subtype=Translate.*, accept-encoding
0, 1, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*subtype=Translate.*, accept-encoding, identity
1, 100, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*subtype=Translate.*, 
# ==================================================
# 6. External lyrics response JSON
# 原始脚本：External.Lyrics.response.bundle.js
# Phase: Response
# Operation: Rewrite
# Script Base64: 请自行填写
# ==================================================
0, 2, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=External.*, accept-encoding
0, 1, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=External.*, accept-encoding, identity
1, 100, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?.*format=json.*subtype=External.*, 
# ==================================================
# 7. External lyrics response Proto
# 原始脚本：External.Lyrics.response.bundle.js
# Phase: Response
# Operation: Rewrite
# Script Base64: 请自行填写
# ==================================================
0, 2, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*subtype=External.*, accept-encoding
0, 1, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*subtype=External.*, accept-encoding, identity
1, 100, ^https?:\/\/(?:.+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*subtype=External.*, 
