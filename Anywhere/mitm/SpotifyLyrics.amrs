# 🍿️ DualSubs: 🎵 Spotify - Anywhere MITM RuleSet（完善版）
# desc = Spotify 增强及双语歌词：Translate + External
# version = Spotify 1.9.12 / Universal 1.7.5
# arguments = Types="Translate,External"&Languages[0]="AUTO"&Languages[1]="ZH"&Vendor="Google"&LrcVendor="NeteaseMusic"&LogLevel="WARN"
# 说明：
# - request.bundle.js 用 Request + Rewrite 处理歌词请求 URL。
# - Translate.response.bundle.js / External.Lyrics.response.bundle.js 用 Response + Rewrite 处理歌词响应。
# - Proto 规则加入 (?!.*format=json)，避免 JSON 与 Proto 规则重复命中。
# - Response body 脚本前仍在 Request 阶段处理 accept-encoding，避免 gzip/br 压缩影响 bodyBytes。

name = DualSubs Spotify Lyrics
hostname = api.spotify.com, spclient.wg.spotify.com, *-spclient.spotify.com

# ===============================
# Request: Lyrics request JSON
# Operation: Rewrite
# ===============================
0, 100, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?(?=.*format=json).*, 

# ===============================
# Request: Lyrics request Proto
# Operation: Rewrite
# ===============================
0, 100, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json).*, 

# ===============================
# Response: Translate lyrics JSON
# Operations: Request Header Delete/Add + Response Rewrite
# ===============================
0, 2, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?(?=.*format=json)(?=.*subtype=Translate).*, accept-encoding
0, 1, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?(?=.*format=json)(?=.*subtype=Translate).*, accept-encoding, identity
1, 100, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?(?=.*format=json)(?=.*subtype=Translate).*, 

# ===============================
# Response: Translate lyrics Proto
# Operations: Request Header Delete/Add + Response Rewrite
# ===============================
0, 2, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json)(?=.*subtype=Translate).*, accept-encoding
0, 1, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json)(?=.*subtype=Translate).*, accept-encoding, identity
1, 100, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json)(?=.*subtype=Translate).*, 

# ===============================
# Response: External lyrics JSON
# Operations: Request Header Delete/Add + Response Rewrite
# ===============================
0, 2, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?(?=.*format=json)(?=.*subtype=External).*, accept-encoding
0, 1, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?(?=.*format=json)(?=.*subtype=External).*, accept-encoding, identity
1, 100, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/.+\?(?=.*format=json)(?=.*subtype=External).*, 

# ===============================
# Response: External lyrics Proto
# Operations: Request Header Delete/Add + Response Rewrite
# ===============================
0, 2, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json)(?=.*subtype=External).*, accept-encoding
0, 1, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json)(?=.*subtype=External).*, accept-encoding, identity
1, 100, ^https?:\/\/(?:[^\/]+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/color-lyrics\/v2\/track\/\w+\?(?!.*format=json)(?=.*subtype=External).*, 
