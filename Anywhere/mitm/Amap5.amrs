# 高德地图去广告 - 纯规则方案
name = 高德地图去广告
hostname = m5.amap.com, m5-zb.amap.com, info.amap.com

# ============================================================
# 开屏广告
1, 5, ^https?://m5\.amap\.com/.*/splash_screen, replace, $.data.ad[*].set.setting.display_time, 0
1, 5, ^https?://m5\.amap\.com/.*/splash_screen, replace, $.data.ad[*].creative[0].start_time, 3818332800
1, 5, ^https?://m5\.amap\.com/.*/splash_screen, replace, $.data.ad[*].creative[0].end_time, 3818419199

# ============================================================
# 打车页面
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/car/order/content_info, replace, $.data.lubanData.benefitsCard.dataList, []
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/car/order/content_info, replace, $.data.lubanData.popup.dataList, []
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/car/order/content_info, replace, $.data.lubanData.skin.dataList, []
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/car/order/content_info, replace, $.data.matrixData.c3DiversionCard.dataList, []
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/car/order/content_info, replace, $.data.matrixData.DiversionCard.dataList, []

# 打车页面其他推广
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/order_web/friendly_information, delete, $.data["105"].banners
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/order_web/friendly_information, delete, $.data["105"].carouselTips
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/order_web/friendly_information, delete, $.data["105"].integratedBanners
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/order_web/friendly_information, delete, $.data["105"].integratedTips
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/order_web/friendly_information, delete, $.data["105"].skins
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/order_web/friendly_information, delete, $.data["105"].skinAndTips
1, 5, ^https?://m5-zb\.amap\.com/.*/boss/order_web/friendly_information, delete, $.data["105"].tips

# 打车推广资源
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.alpha
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.banner
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.bravo
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.bubble
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.charlie
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.icon
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.other
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.popup
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.push
1, 5, ^https?://m5-zb\.amap\.com/.*/promotion-web/resource, delete, $.data.tips

# ============================================================
# 我的页面
1, 5, ^https?://m5\.amap\.com/.*/shield/dsp/profile/index/nodefaasv3, delete, $.data.tipData
1, 5, ^https?://m5\.amap\.com/.*/shield/dsp/profile/index/nodefaasv3, delete, $.data.memberInfo
1, 5, ^https?://m5\.amap\.com/.*/shield/dsp/profile/index/nodefaasv3, delete, $.data.topMixedCard
1, 5, ^https?://m5\.amap\.com/.*/shield/dsp/profile/index/nodefaasv3, replace, $.data.cardList, [{"dataKey":"MyOrderCard"}]

# ============================================================
# 搜索热词
1, 5, ^https?://m5\.amap\.com/.*/shield/search_bff/hotword, replace, $.data.headerHotWord, []

# ============================================================
# 公交列表
1, 5, ^https?://m5\.amap\.com/.*/bus/plan/integrate, replace, $.data.banner_lists.data, []
1, 5, ^https?://m5\.amap\.com/.*/bus/plan/integrate, replace, $.data.banner_lists.tips, []
1, 5, ^https?://m5\.amap\.com/.*/bus/plan/integrate, replace, $.data.mixed_plans.data.taxiPlans, []

# ============================================================
# 酒店/景区
1, 5, ^https?://m5\.amap\.com/.*/c3frontend/af-hotel/page/main, delete, $.data.modules.CouponPortalCard
1, 5, ^https?://m5\.amap\.com/.*/c3frontend/af-hotel/page/main, delete, $.data.modules.CouponWidget
1, 5, ^https?://m5\.amap\.com/.*/c3frontend/af-hotel/page/main, delete, $.data.modules.recommended_list
