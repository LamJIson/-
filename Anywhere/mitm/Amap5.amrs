1, 5, ^https?://(?:info|m5)\.amap\.com/.*/shield/search/common/coupon/info, replace, $.data, {}

# ============================================================
# 搜索建议 - 过滤广告
1, 5, ^https?://m5\.amap\.com/.*/shield/search_poi/sug, remove-where-field-in, $.tip_list, tip.result_type, ad, poi_ad, toplist
1, 5, ^https?://m5\.amap\.com/.*/shield/search_poi/sug, remove-where-field-in, $.tip_list, tip.task_tag, ad, exct_query_sug_merge_theme, query_sug_merge_theme, sp
