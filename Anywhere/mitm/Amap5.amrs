1, 5, ^https?://m5\.amap\.com/.*/c3frontend/af-hotel/page/main, delete, $.data.modules.user_filter_card.data.bannerList
1, 5, ^https?://m5\.amap\.com/.*/c3frontend/af-hotel/page/main, delete, $.data.modules.user_filter_card.data.service_data
1, 5, ^https?://m5\.amap\.com/.*/c3frontend/af-hotel/page/main, delete, $.data.modules.user_filter_card.data.sug_items_data
1, 5, ^https?://m5\.amap\.com/.*/c3frontend/af-hotel/page/main, delete, $.data.modules.user_filter_card.data.search_button_data.rightbgText

